  "Expression": "\nROUND(CALCULATE(SUM(CTRL_ESTOQ_SALDO[QT_ESTOQUE]),\n            ALLEXCEPT(CTRL_ESTOQ_SALDO,CTRL_ESTOQ_SALDO[CD_INSUMO])\n        ),2)\n- ROUND(SUM(CTRL_ESTOQ_SALDO[QT_RESERVA]),2)"
