 {
  "Kind": "Coluna calculada",
  "Table": "FUNC_DIV",
  "Name": "DIV",
  "Auto": false,
  "Expression": "\nIF(OR([TURNO]=\"DIV\",[TURNO]=\"NI\"),BLANK(),\nIF(OR([TURNO]<>[TURNO_FUNC],[CD_LOC_ESCALA]<>[CD_LOC_RH]),1,BLANK()\n))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "FUNC_DIV",
  "Name": "TP_DIV",
  "Auto": false,
  "Expression": "\nIF([DIV]=BLANK(),BLANK(),\nIF(AND([TURNO]<>[TURNO_FUNC],[CD_LOC_ESCALA]<>[CD_LOC_RH]),\"1 - Turno e Local de Pagamento\",\nIF([TURNO]<>[TURNO_FUNC],\"2 - Turno\",\"3 - Local de Pagamento <> Frente\"\n)))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "FUNC_DIV",
  "Name": "LIDER_APTO",
  "Auto": false,
  "Expression": "\nIF([DE_LIDER]=BLANK(),[RESP_APTO] & \" - \" & [DE_RESP_APTO], [LIDER] & \" - \" & [DE_LIDER])"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "ORDEM_SERVICO_DOSE",
  "Name": "QTDE_DOSE",
  "Auto": false,
  "Expression": "\nROUND(DIVIDE([QTDE_PRODUTO],[QTDE_AREA]),3)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "ORDEM_SERVICO_DOSE",
  "Name": "CHECK_DOSE",
  "Auto": false,
  "Expression": "\nIF(OR([QTDE_DOSE]<[DOSE_MIN],[QTDE_DOSE]>[DOSE_MAX]),\"Verificar Item\",BLANK())"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "ORDEM_SERVICO_DOSE",
  "Name": "QTDE_CHECK",
  "Auto": false,
  "Expression": "\nIF([CHECK_DOSE]=BLANK(),BLANK(),1)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "ORDEM_SERVICO_DOSE",
  "Name": "CHECK_OS",
  "Auto": false,
  "Expression": "\nVAR N_OS = [NO_OS]\nRETURN\nIF(CALCULATE(SUM([QTDE_CHECK]),FILTER(ORDEM_SERVICO_DOSE,[NO_OS]=N_OS)) = 0, BLANK(), \"Verificar O.S.\")"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "PRD_YTD_R",
  "Auto": false,
  "Expression": "\nVAR PRC = [PROCESSO]\nVAR GRP = [CD_GRUPO]\n\nRETURN\n\nCALCULATE(SUM(CST_OS[QT_AREA]),\n    CST_OS[PROCESSO] = PRC,\n    CST_OS[CD_GRUPO] = GRP)\n+\nCALCULATE(SUM(CST_REALIZADO[PRD_YTD_R]),\n    CST_REALIZADO[PROCESSO] = PRC,\n    CST_REALIZADO[CD_GRUPO] = GRP)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "VLR_YTD_R",
  "Auto": false,
  "Expression": "\nVAR PRC = [PROCESSO]\nVAR GRP = [CD_GRUPO]\n\nRETURN\n\nCALCULATE(SUM(CST_OS[VL_OS]),\n    CST_OS[PROCESSO] = PRC,\n    CST_OS[CD_GRUPO] = GRP)\n+\nCALCULATE(SUM(CST_REALIZADO[VLR_YTD_R]),\n    CST_REALIZADO[PROCESSO] = PRC,\n    CST_REALIZADO[CD_GRUPO] = GRP)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "REGRA",
  "Auto": false,
  "Expression": "\nIF(OR([VLR_YTD_R]>[VLR_TT],[VLR_YTD_R]>[VLR_YTD]),1,\nIF(OR([PRD_YTD_R]>[PRD_TT],[PRD_YTD_R]>[PRD_YTD]),1,0))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "UNIT_YTD",
  "Auto": false,
  "Expression": "\nROUND(IFERROR([VLR_YTD]/[PRD_YTD],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "UNIT_TT",
  "Auto": false,
  "Expression": "\nROUND(IFERROR([VLR_TT]/[PRD_TT],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_ORCAMENTO",
  "Name": "UNIT_REAL",
  "Auto": false,
  "Expression": "\nROUND(IFERROR([VLR_YTD_R]/[PRD_YTD_R],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "PRD_TT",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_TT],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0, \n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_TT],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "PRD_YTD",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_YTD],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0,\n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_YTD],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "PRD_REAL",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_YTD_R],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0, \n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[PRD_YTD_R],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "VLR_TT",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_TT],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0,\n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_TT],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "VLR_YTD",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_YTD],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0,\n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_YTD],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "VLR_REAL",
  "Auto": false,
  "Expression": "\nIF(ISBLANK(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_YTD_R],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO])\n            ), 0,\n            ROUND(\n            LOOKUPVALUE(CST_ORCAMENTO[VLR_YTD_R],\n                        CST_ORCAMENTO[PROCESSO],[PROCESSO],\n                        CST_ORCAMENTO[CD_GRUPO],[CD_GRUPO]),2)\n)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "UNIT_TT",
  "Auto": false,
  "Expression": "\nROUND(IFERROR([VLR_TT]/[PRD_TT],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "UNIT_YTD",
  "Auto": false,
  "Expression": "\nROUND(IFERROR([VLR_YTD]/[PRD_YTD],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "UNIT_REAL",
