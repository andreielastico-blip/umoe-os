  "Expression": "\nROUND(IFERROR([VLR_REAL]/[PRD_REAL],0),2)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "CST_OS",
  "Name": "ALERTA",
  "Auto": false,
  "Expression": "\nIF([VLR_REAL]>[VLR_TT],\"Gasto real maior que Gasto orçado total\",\nIF([CST_UNIT]>[UNIT_TT],\"Custo unitário da OS maior que Custo unitário Total orçado\",\nIF([PRD_REAL]>[PRD_TT],\"Produção realizada maior do que Produção Total orçada\",\nBLANK()\n)))"
 },
 {
