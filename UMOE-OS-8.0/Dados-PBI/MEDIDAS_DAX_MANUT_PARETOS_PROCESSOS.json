[
 {
  "Kind": "Medida",
  "Table": "Paretos",
  "Name": "Lista de SISTEMA valores",
  "Auto": false,
  "Expression": "\nVAR __DISTINCT_VALUES_COUNT = DISTINCTCOUNT('Paretos'[SISTEMA])\nVAR __MAX_VALUES_TO_SHOW = 3\nRETURN\n\tIF(\n\t\t__DISTINCT_VALUES_COUNT > __MAX_VALUES_TO_SHOW,\n\t\tCONCATENATE(\n\t\t\tCONCATENATEX(\n\t\t\t\tTOPN(\n\t\t\t\t\t__MAX_VALUES_TO_SHOW,\n\t\t\t\t\tVALUES('Paretos'[SISTEMA]),\n\t\t\t\t\t'Paretos'[SISTEMA],\n\t\t\t\t\tASC\n\t\t\t\t),\n\t\t\t\t'Paretos'[SISTEMA],\n\t\t\t\t\", \",\n\t\t\t\t'Paretos'[SISTEMA],\n\t\t\t\tASC\n\t\t\t),\n\t\t\t\",  etc.\"\n\t\t),\n\t\tCONCATENATEX(\n\t\t\tVALUES('Paretos'[SISTEMA]),\n\t\t\t'Paretos'[SISTEMA],\n\t\t\t\", \",\n\t\t\t'Paretos'[SISTEMA],\n\t\t\tASC\n\t\t)\n\t)"
 },
 {
  "Kind": "Medida",
  "Table": "Paretos",
  "Name": "MTTR",
  "Auto": false,
  "Expression": "\nDIVIDE(\n\tSUM('Paretos'[Tempo dePermanência(h)]),\n\tCOUNTA('Paretos'[SISTEMA])\n)"
 },
 {
  "Kind": "Medida",
  "Table": "Paretos",
  "Name": "limite mttr",
  "Auto": false,
  "Expression": "\nDIVIDE(\n\tSUM('Paretos'[Tempo dePermanência(h)]),\n\tCOUNTA('Paretos'[Boletim])\n)"
 },
 {
  "Kind": "Medida",
  "Table": "Paretos",
  "Name": "limite N",
  "Auto": false,
  "Expression": "\nDIVIDE(COUNTA('Paretos'[Boletim]), DISTINCTCOUNT('Paretos'[SISTEMA]))"
 },
