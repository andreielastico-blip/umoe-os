 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Status Previsao",
  "Auto": false,
  "Expression": "IF(ISBLANK('Base O.S'[Previsao de Saida]),\"Aguardando Previsão\",IF(('Base O.S'[Previsao de Saida]- NOW() ) < 0,\"Atrasado\",\"Dentro da Previsão\"))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Tempo Permanencia",
  "Auto": false,
  "Expression": "DATEDIFF([HR_ENTRADA],NOW(),DAY)"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Indice",
  "Auto": false,
  "Expression": "IF(AND([Tempo Permanencia] >= 0,'BASE O.S'[Tempo Permanencia] <= 1),\"0-1 Dias\",IF(AND('BASE O.S'[Tempo Permanencia]>1,'BASE O.S'[Tempo Permanencia] <=5 ),\"2-5 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] >5,'BASE O.S'[Tempo Permanencia] <=10),\"6-10 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] > 10,'BASE O.S'[Tempo Permanencia] <= 15),\"11-15 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] > 15,'BASE O.S'[Tempo Permanencia] <= 20),\"16-20 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] >15,'BASE O.S'[Tempo Permanencia] <= 25),\"21-25 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] >25,'BASE O.S'[Tempo Permanencia] <=35),\"26-35 Dias\",IF(AND('BASE O.S'[Tempo Permanencia] >36,'BASE O.S'[Tempo Permanencia] <=60),\"36-60 Dias\",\"+61 Dias\"))))))))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Coluna",
  "Auto": false,
  "Expression": "NOW() - 'Base O.S'[DT_ENTRADA]"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Tempo Horas",
  "Auto": false,
  "Expression": "'Base O.S'[Coluna] * 24"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Posicao",
  "Auto": false,
  "Expression": "IF(AND([Tempo Permanencia] >= 0,'BASE O.S'[Tempo Permanencia] <= 1),\"1\",IF(AND('BASE O.S'[Tempo Permanencia]>1,'BASE O.S'[Tempo Permanencia] <=5 ),\"2\",IF(AND('BASE O.S'[Tempo Permanencia] >5,'BASE O.S'[Tempo Permanencia] <=10),\"3\",IF(AND('BASE O.S'[Tempo Permanencia] > 10,'BASE O.S'[Tempo Permanencia] <= 15),\"4\",IF(AND('BASE O.S'[Tempo Permanencia] > 15,'BASE O.S'[Tempo Permanencia] <= 20),\"5\",IF(AND('BASE O.S'[Tempo Permanencia] >15,'BASE O.S'[Tempo Permanencia] <= 25),\"6\",IF(AND('BASE O.S'[Tempo Permanencia] >25,'BASE O.S'[Tempo Permanencia] <=35),\"7\",IF(AND('BASE O.S'[Tempo Permanencia] >36,'BASE O.S'[Tempo Permanencia] <=60),\"8\",\"9\"))))))))"
 },
 {
  "Kind": "Coluna calculada",
  "Table": "Base O.S",
  "Name": "Localização",
  "Auto": false,
  "Expression": "RELATED('Tabela Fornecedores'[Município])&\";\"&RELATED('Tabela Fornecedores'[UF])"
