# ── Credenciais e segredos ─────────────────────────────────────────
.env
*.env
secrets.json
credentials.json
service-account*.json
# Cache de token MSAL (contem tokens de acesso/refresh do Power BI)
.token_cache.json
**/.token_cache.json
config/.token_cache.json

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Dados sensíveis / grandes arquivos locais ──────────────────────
# Planilhas originais (ficam so localmente, não no repo)
*.xlsb
*.xlsm
# Dados brutos extraidos do Power BI (~1GB) ficam locais; pipeline le deles.
UMOE-OS-8.0/Dados-PBI/*.json
!UMOE-OS-8.0/Dados-PBI/_extract_status.json
# Exceção: arquivos gerados pelo pipeline (HTML relatórios)
!UMOE-OS-8.0/Relatorios/*.html
!docs/*.html

# ── Logs granulares (manter só os gerados pelo pipeline) ──────────
logs/*.log
!logs/.gitkeep

# ── PDFs originais (grandes, ficam local) ─────────────────────────
*.pdf

# ── OS / IDE ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp

# ── Temporários ────────────────────────────────────────────────────
*.tmp
*.bak
~$*
