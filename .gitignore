# -- Credenciais e segredos ---------------------------------------------------
.env
*.env
secrets.json
credentials.json
service-account*.json
.token_cache.json
**/.token_cache.json
config/.token_cache.json

# -- Python -------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# -- Planilhas / binarios Office (ficam local, nunca no repo) -----------------
*.xlsx
*.xlsb
*.xlsm
*.xlsm
*.pbix

# -- Dados brutos Power BI (~1 GB, regeneraveis) ------------------------------
UMOE-OS-8.0/Dados-PBI/*.json
UMOE-OS-8.0/Dados-PBI/MANUT/
UMOE-OS-8.0/Dados-PBI/PBIX/
UMOE-OS-8.0/Dados-PBI/_tmp/
# Excecao: status da ultima extracao (pequeno, util para auditoria)
!UMOE-OS-8.0/Dados-PBI/_extract_status.json
# Excecao: catalogo de formulas DAX (pequeno, fonte de verdade dos calculos)
!UMOE-OS-8.0/Dados-PBI/MEDIDAS_DAX_*.json
# Excecao: valores ao vivo das medidas (auditoria dos KPIs)
!UMOE-OS-8.0/Dados-PBI/MEDIDAS_VALORES.json

# -- Solinftec CSVs (dados brutos diarios, regeneraveis do sistema) -----------
UMOE-OS-8.0/Solinftec/*.csv

# -- Snapshots JSON gerados pelo pipeline (regeneraveis, causam churn) --------
UMOE-OS-8.0/99-SSoT/umoe-*-snapshot.json
UMOE-OS-8.0/Relatorios/pipeline-status.json

# -- Relatorios HTML gerados (regeneraveis, grandes, causam churn) ------------
# Regra: o codigo que os gera fica no repo; os HTMLs ficam local.
UMOE-OS-8.0/Relatorios/*.html
UMOE-OS-8.0/Relatorios/*.pdf
docs/*.html
# Excecao: paginas de navegacao estaticas (nao geradas pelo pipeline)
!docs/index.html
!docs/pbi-hub.html
# Excecao: catalogo DAX (referencia estavel das formulas, muda raramente)
!docs/UMOE_Catalogo_DAX.html
# Excecao: dashboard espelho do BI (KPIs com regras DAX oficiais)
!docs/UMOE_Dashboard_BI.html
# Excecao: painel 100% dos KPIs do BI (valores ao vivo)
!docs/UMOE_KPIs_BI.html

# -- PDFs (originais grandes, ficam local) ------------------------------------
*.pdf

# -- Logs (gerados localmente, nao versionados) -------------------------------
logs/*.log
!logs/.gitkeep

# -- OS / IDE -----------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp

# -- Temporarios --------------------------------------------------------------
*.tmp
*.bak
~$*
