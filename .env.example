# UMOE OS 8.0 - Variaveis de Ambiente
# Copie para .env e preencha (NUNCA commitar o .env real)

# Power BI Service Principal (Azure AD)
# Criar em: portal.azure.com > App registrations
PBI_TENANT_ID=seu-tenant-id-aqui
PBI_CLIENT_ID=seu-client-id-aqui
PBI_CLIENT_SECRET=seu-client-secret-aqui

# GitHub (para push automatico)
GITHUB_TOKEN=seu-github-token-aqui
GITHUB_REPO=andreielastico-blip/umoe-os

# Anthropic (para insights de IA)
ANTHROPIC_API_KEY=sua-chave-aqui

# Notificacoes (opcional)
TEAMS_WEBHOOK_URL=
EMAIL_ALERT=andreielastico@gmail.com
